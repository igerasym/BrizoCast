# BrizoCast — example environment configuration.
#
# Copy this file to `.env` and fill in the values. Field names map directly to
# the Settings model in brizocast/config/settings.py (case-insensitive).
# Lines below show each setting's default; only TELEGRAM_BOT_TOKEN is required.

# === Telegram & core ========================================================

# REQUIRED. Bot token issued by @BotFather. Startup fails (naming this field)
# if it is missing or empty.
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token-here

# SQLAlchemy async database URL. Defaults to a SQLite file inside the mounted
# ./data volume (see docker-compose.yml). Keep the path under data/ so it
# persists across container restarts.
DATABASE_URL=sqlite+aiosqlite:///data/brizocast.db

# How often (in minutes) the scheduler runs the forecast-check job. >= 1.
SCHEDULER_INTERVAL_MINUTES=60

# === Forecast / geocoding ===================================================

# Forecast provider key. Unspecified resolves to Open-Meteo Marine.
FORECAST_PROVIDER=open_meteo_marine

# Geocoding provider key (city/place lookup).
GEOCODING_PROVIDER=open_meteo_geocoding

# Per-spot forecast cache time-to-live in minutes. A cached forecast younger
# than this is reused without calling the provider. >= 1.
FORECAST_CACHE_TTL_MINUTES=180

# === Notifications ==========================================================

# Minimum score-point increase over the last alert (per forecast window) before
# a follow-up "improved" alert is sent. Higher = quieter. >= 0.
SIGNIFICANT_IMPROVEMENT=10

# How many times to retry a failed Telegram delivery before deferring it to the
# next digest. >= 0.
NOTIFY_RETRY_COUNT=3

# Local time-of-day the morning digest is sent (HH:MM, 24h).
MORNING_DIGEST_TIME=07:00

# Local time-of-day the evening digest is sent (HH:MM, 24h).
EVENING_DIGEST_TIME=18:00

# Weekly "best day" digest schedule: DAY HH:MM (e.g. MON 07:00).
WEEKLY_DIGEST=MON 07:00

# === AI (optional) ==========================================================

# Enable AI-assisted preset generation. When false, a no-op provider is used.
AI_ENABLED=false

# AI provider key. Used only when AI_ENABLED=true; unspecified resolves to
# Gemini.
AI_PROVIDER=gemini

# API key for the AI provider. Required only when AI_ENABLED=true.
AI_API_KEY=

# Model name passed to the AI provider.
AI_MODEL=gemini-3.1-flash-lite

# === Monetization ===========================================================

# Enable plan-based entitlement gating. When false, every user is treated as
# fully entitled (plan limits are ignored).
MONETIZATION_ENABLED=false

# Note: PLAN_LIMITS (per-tier subscription caps and notification modes) is a
# structured value with sensible built-in defaults and is normally configured
# in code rather than here. Override via environment only for advanced setups.
# === Admin web panel ========================================================

# Username for logging into the admin web panel. Required by the panel.
ADMIN_USERNAME=admin

# Password for logging into the admin web panel. Required by the panel.
# Change this to a strong, unique value before deploying.
ADMIN_PASSWORD=change-me-please

# LAN address the admin panel binds/publishes on. Set this to your Raspberry
# Pi's LAN IP (e.g. 192.168.1.50) so the panel is reachable only on your local
# network. NEVER set this to 0.0.0.0 — that exposes the panel on all network
# interfaces, including the public internet. Use 127.0.0.1 for local-only.
ADMIN_BIND_HOST=127.0.0.1

# Host port the admin panel is published on.
ADMIN_PORT=8080

# Path to the surf spots dataset. Optional; defaults to data/surf_spots.json.
# SPOT_DATASET_PATH=data/surf_spots.json
